<!DOCTYPE html>
<html lang="en">
<%- include('../partials/head', {title: 'Join Sky Blog - Create Your Account'}) %>
<body class="antialiased text-slate-800 bg-slate-50">

    <!-- Simple Navbar for Auth Pages -->
    <nav class="fixed w-full z-50 bg-white/80 backdrop-blur-md border-b border-slate-200/50">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between items-center h-16">
                <a href="/" class="flex items-center">
                    <div class="w-8 h-8 rounded-full sky-gradient flex items-center justify-center text-white font-bold text-sm mr-2">
                        <i class="fas fa-cloud"></i>
                    </div>
                    <span class="font-serif text-xl font-bold text-slate-800">Sky</span>
                    <span class="font-serif text-xl font-bold text-sky-500">Blog</span>
                </a>
                <div class="text-sm text-slate-600">
                    Already have an account? 
                    <a href="/login" class="text-sky-600 font-semibold hover:text-sky-700 transition">Sign in</a>
                </div>
            </div>
        </div>
    </nav>

    <!-- Signup Section -->
    <section class="min-h-screen pt-16 flex items-center justify-center relative overflow-hidden">
        <!-- Background Elements -->
        <div class="absolute inset-0 overflow-hidden pointer-events-none">
            <!-- Sky Gradient -->
            <div class="absolute top-0 left-0 w-full h-full bg-gradient-to-br from-sky-400/10 via-blue-500/5 to-indigo-500/10"></div>
            
            <!-- Floating Clouds -->
            <div class="absolute top-20 left-10 w-64 h-20 bg-white/60 rounded-full blur-2xl floating"></div>
            <div class="absolute top-40 right-20 w-80 h-24 bg-sky-200/40 rounded-full blur-3xl drifting" style="animation-delay: 2s;"></div>
            <div class="absolute bottom-32 left-1/4 w-96 h-32 bg-blue-200/30 rounded-full blur-3xl floating" style="animation-delay: 4s;"></div>
            <div class="absolute bottom-20 right-10 w-72 h-24 bg-indigo-200/30 rounded-full blur-2xl drifting" style="animation-delay: 3s;"></div>
            
            <!-- Sun -->
            <div class="absolute -top-40 -right-40 w-96 h-96 bg-gradient-to-br from-yellow-300/40 to-orange-400/30 rounded-full blur-3xl"></div>
        </div>

        <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 w-full relative z-10 py-12">
            <div class="grid lg:grid-cols-2 gap-12 items-center">
                
                <!-- Left Side - Value Proposition -->
                <div class="hidden lg:block space-y-8">
                    <div>
                        <h1 class="font-serif text-5xl font-bold text-slate-800 leading-tight mb-4">
                            Start Your <br>
                            <span class="text-transparent bg-clip-text bg-gradient-to-r from-sky-500 to-indigo-600">Writing Journey</span>
                        </h1>
                        <p class="text-xl text-slate-600 leading-relaxed">
                            Join 50,000+ writers and readers on Sky Blog. Share your stories, build your audience, and soar above the ordinary.
                        </p>
                    </div>

                    <!-- Benefits -->
                    <div class="space-y-4">
                        <div class="flex items-start gap-4 p-4 rounded-xl bg-white/60 backdrop-blur-sm border border-white/50 shadow-sm">
                            <div class="w-12 h-12 rounded-full bg-sky-100 flex items-center justify-center text-sky-600 flex-shrink-0">
                                <i class="fas fa-feather-alt text-xl"></i>
                            </div>
                            <div>
                                <h3 class="font-semibold text-slate-800 mb-1">Unlimited Stories</h3>
                                <p class="text-sm text-slate-600">Write as much as you want. No limits, no restrictions.</p>
                            </div>
                        </div>

                        <div class="flex items-start gap-4 p-4 rounded-xl bg-white/60 backdrop-blur-sm border border-white/50 shadow-sm">
                            <div class="w-12 h-12 rounded-full bg-indigo-100 flex items-center justify-center text-indigo-600 flex-shrink-0">
                                <i class="fas fa-users text-xl"></i>
                            </div>
                            <div>
                                <h3 class="font-semibold text-slate-800 mb-1">Built-in Audience</h3>
                                <p class="text-sm text-slate-600">Connect with readers who care about your topics.</p>
                            </div>
                        </div>

                        <div class="flex items-start gap-4 p-4 rounded-xl bg-white/60 backdrop-blur-sm border border-white/50 shadow-sm">
                            <div class="w-12 h-12 rounded-full bg-orange-100 flex items-center justify-center text-orange-600 flex-shrink-0">
                                <i class="fas fa-chart-line text-xl"></i>
                            </div>
                            <div>
                                <h3 class="font-semibold text-slate-800 mb-1">Detailed Analytics</h3>
                                <p class="text-sm text-slate-600">Track your growth with comprehensive insights.</p>
                            </div>
                        </div>
                    </div>

                    <!-- Testimonial -->
                    <div class="bg-white/80 backdrop-blur-sm rounded-2xl p-6 border border-white/50 shadow-lg">
                        <div class="flex items-center gap-1 text-yellow-400 mb-3">
                            <i class="fas fa-star"></i>
                            <i class="fas fa-star"></i>
                            <i class="fas fa-star"></i>
                            <i class="fas fa-star"></i>
                            <i class="fas fa-star"></i>
                        </div>
                        <p class="text-slate-700 mb-4 italic">"Sky Blog transformed my writing career. The community here is incredibly supportive and the platform is a joy to use."</p>
                        <div class="flex items-center gap-3">
                            <img src="https://images.unsplash.com/photo-1494790108377-be9c29b29330?w=100&q=80" class="w-10 h-10 rounded-full object-cover">
                            <div>
                                <div class="font-semibold text-slate-800">Sarah Chen</div>
                                <div class="text-sm text-slate-500">Top Writer, 50K followers</div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Right Side - Signup Form -->
                <div class="w-full max-w-md mx-auto lg:max-w-none">
                    <div class="bg-white rounded-3xl shadow-xl shadow-sky-900/5 border border-slate-100 overflow-hidden">
                        <!-- Form Header -->
                        <div class="bg-gradient-to-r from-sky-500 to-indigo-600 p-8 text-center relative overflow-hidden">
                            <div class="absolute inset-0 opacity-20">
                                <div class="absolute top-0 left-0 w-full h-full bg-[url('https://www.transparenttextures.com/patterns/cubes.png')]"></div>
                            </div>
                            <div class="relative z-10">
                                <div class="w-16 h-16 mx-auto bg-white/20 backdrop-blur-sm rounded-full flex items-center justify-center text-white text-2xl mb-4 border border-white/30">
                                    <i class="fas fa-user-plus"></i>
                                </div>
                                <h2 class="text-2xl font-bold text-white mb-2">Create Account</h2>
                                <p class="text-sky-100 text-sm">Join the Sky Blog community today</p>
                            </div>
                        </div>

                        <!-- Form Body -->
                        <div class="p-8 space-y-6">
                            <!-- Social Signup -->
                            <div class="grid grid-cols-2 gap-3">
                                <button type="button" onclick="socialSignup('google')" class="flex items-center justify-center gap-2 px-4 py-3 border border-slate-200 rounded-xl hover:bg-slate-50 hover:border-slate-300 transition group">
                                    <img src="https://www.svgrepo.com/show/475656/google-color.svg" class="w-5 h-5" alt="Google">
                                    <span class="text-sm font-medium text-slate-700 group-hover:text-slate-900">Google</span>
                                </button>
                                <button type="button" onclick="socialSignup('github')" class="flex items-center justify-center gap-2 px-4 py-3 border border-slate-200 rounded-xl hover:bg-slate-50 hover:border-slate-300 transition group">
                                    <i class="fab fa-github text-xl text-slate-800"></i>
                                    <span class="text-sm font-medium text-slate-700 group-hover:text-slate-900">GitHub</span>
                                </button>
                            </div>

                            <div class="relative">
                                <div class="absolute inset-0 flex items-center">
                                    <div class="w-full border-t border-slate-200"></div>
                                </div>
                                <div class="relative flex justify-center text-sm">
                                    <span class="px-4 bg-white text-slate-500">Or continue with email</span>
                                </div>
                            </div>

                            <!-- Signup Form -->
                            <form id="signupForm" onsubmit="handleSignup(event)" class="space-y-4">
                                <!-- Name Fields -->
                                <div class="grid grid-cols-2 gap-4">
                                    <div>
                                        <label class="block text-sm font-medium text-slate-700 mb-1">First Name</label>
                                        <input type="text" name="firstName" required
                                            class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:border-sky-500 focus:ring-2 focus:ring-sky-200 transition outline-none"
                                            placeholder="John">
                                    </div>
                                    <div>
                                        <label class="block text-sm font-medium text-slate-700 mb-1">Last Name</label>
                                        <input type="text" name="lastName" required
                                            class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:border-sky-500 focus:ring-2 focus:ring-sky-200 transition outline-none"
                                            placeholder="Doe">
                                    </div>
                                </div>

                                <!-- Username -->
                                <div>
                                    <label class="block text-sm font-medium text-slate-700 mb-1">Username</label>
                                    <div class="relative">
                                        <span class="absolute left-4 top-1/2 -translate-y-1/2 text-slate-400">@</span>
                                        <input type="text" name="username" required
                                            class="w-full pl-8 pr-4 py-3 rounded-xl border border-slate-200 focus:border-sky-500 focus:ring-2 focus:ring-sky-200 transition outline-none"
                                            placeholder="johndoe"
                                            oninput="validateUsername(this)">
                                    </div>
                                    <p id="usernameFeedback" class="text-xs mt-1 hidden"></p>
                                </div>

                                <!-- Email -->
                                <div>
                                    <label class="block text-sm font-medium text-slate-700 mb-1">Email Address</label>
                                    <input type="email" name="email" required
                                        class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:border-sky-500 focus:ring-2 focus:ring-sky-200 transition outline-none"
                                        placeholder="john@example.com"
                                        oninput="validateEmail(this)">
                                    <p id="emailFeedback" class="text-xs mt-1 hidden"></p>
                                </div>

                                <!-- Password -->
                                <div>
                                    <label class="block text-sm font-medium text-slate-700 mb-1">Password</label>
                                    <div class="relative">
                                        <input type="password" name="password" id="password" required
                                            class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:border-sky-500 focus:ring-2 focus:ring-sky-200 transition outline-none pr-12"
                                            placeholder="••••••••"
                                            oninput="checkPasswordStrength(this.value)">
                                        <button type="button" onclick="togglePassword('password', this)" 
                                            class="absolute right-4 top-1/2 -translate-y-1/2 text-slate-400 hover:text-slate-600 transition">
                                            <i class="far fa-eye"></i>
                                        </button>
                                    </div>
                                    
                                    <!-- Password Strength -->
                                    <div class="mt-2 space-y-2">
                                        <div class="flex gap-1">
                                            <div id="strength-1" class="h-1 flex-1 rounded-full bg-slate-200 transition"></div>
                                            <div id="strength-2" class="h-1 flex-1 rounded-full bg-slate-200 transition"></div>
                                            <div id="strength-3" class="h-1 flex-1 rounded-full bg-slate-200 transition"></div>
                                            <div id="strength-4" class="h-1 flex-1 rounded-full bg-slate-200 transition"></div>
                                        </div>
                                        <p id="passwordFeedback" class="text-xs text-slate-500">Use 8+ characters with mix of letters, numbers & symbols</p>
                                    </div>
                                </div>

                                <!-- Confirm Password -->
                                <div>
                                    <label class="block text-sm font-medium text-slate-700 mb-1">Confirm Password</label>
                                    <div class="relative">
                                        <input type="password" name="confirmPassword" id="confirmPassword" required
                                            class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:border-sky-500 focus:ring-2 focus:ring-sky-200 transition outline-none pr-12"
                                            placeholder="••••••••">
                                        <button type="button" onclick="togglePassword('confirmPassword', this)" 
                                            class="absolute right-4 top-1/2 -translate-y-1/2 text-slate-400 hover:text-slate-600 transition">
                                            <i class="far fa-eye"></i>
                                        </button>
                                    </div>
                                </div>

                                <!-- Terms -->
                                <div class="flex items-start gap-3">
                                    <input type="checkbox" id="terms" name="terms" required
                                        class="w-5 h-5 rounded border-slate-300 text-sky-600 focus:ring-sky-500 mt-0.5">
                                    <label for="terms" class="text-sm text-slate-600">
                                        I agree to the <a href="#" class="text-sky-600 hover:underline">Terms of Service</a> and 
                                        <a href="#" class="text-sky-600 hover:underline">Privacy Policy</a>
                                    </label>
                                </div>

                                <!-- Submit Button -->
                                <button type="submit" id="submitBtn"
                                    class="w-full py-4 bg-gradient-to-r from-sky-500 to-indigo-600 text-white rounded-xl font-semibold hover:shadow-lg hover:shadow-sky-500/30 transition transform hover:scale-[1.02] flex items-center justify-center gap-2">
                                    <span>Create Account</span>
                                    <i class="fas fa-arrow-right"></i>
                                </button>
                            </form>

                            <!-- Login Link -->
                            <p class="text-center text-sm text-slate-600">
                                Already have an account? 
                                <a href="/login" class="text-sky-600 font-semibold hover:text-sky-700 transition">Sign in</a>
                            </p>
                        </div>
                    </div>

                    <!-- Trust Badges -->
                    <div class="mt-8 flex justify-center gap-6 text-slate-400">
                        <div class="flex items-center gap-2 text-sm">
                            <i class="fas fa-shield-alt text-sky-500"></i>
                            <span>Secure SSL</span>
                        </div>
                        <div class="flex items-center gap-2 text-sm">
                            <i class="fas fa-lock text-sky-500"></i>
                            <span>Encrypted</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <%- include('../partials/script') %>
    
    <!-- Signup Specific Scripts -->
    <script>
        // Toggle Password Visibility
        function togglePassword(fieldId, btn) {
            const input = document.getElementById(fieldId);
            const icon = btn.querySelector('i');
            
            if (input.type === 'password') {
                input.type = 'text';
                icon.classList.remove('far', 'fa-eye');
                icon.classList.add('far', 'fa-eye-slash');
            } else {
                input.type = 'password';
                icon.classList.remove('far', 'fa-eye-slash');
                icon.classList.add('far', 'fa-eye');
            }
        }

        // Validate Username
        function validateUsername(input) {
            const feedback = document.getElementById('usernameFeedback');
            const value = input.value.trim();
            
            if (value.length < 3) {
                feedback.textContent = 'Username must be at least 3 characters';
                feedback.className = 'text-xs mt-1 text-red-500';
                feedback.classList.remove('hidden');
                return false;
            } else if (!/^[a-zA-Z0-9_]+$/.test(value)) {
                feedback.textContent = 'Only letters, numbers, and underscores allowed';
                feedback.className = 'text-xs mt-1 text-red-500';
                feedback.classList.remove('hidden');
                return false;
            } else {
                feedback.textContent = 'Username available!';
                feedback.className = 'text-xs mt-1 text-green-500';
                feedback.classList.remove('hidden');
                return true;
            }
        }

        // Validate Email
        function validateEmail(input) {
            const feedback = document.getElementById('emailFeedback');
            const value = input.value.trim();
            const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
            
            if (!emailRegex.test(value)) {
                feedback.textContent = 'Please enter a valid email address';
                feedback.className = 'text-xs mt-1 text-red-500';
                feedback.classList.remove('hidden');
                return false;
            } else {
                feedback.textContent = 'Valid email format';
                feedback.className = 'text-xs mt-1 text-green-500';
                feedback.classList.remove('hidden');
                return true;
            }
        }

        // Check Password Strength
        function checkPasswordStrength(password) {
            const bars = [
                document.getElementById('strength-1'),
                document.getElementById('strength-2'),
                document.getElementById('strength-3'),
                document.getElementById('strength-4')
            ];
            const feedback = document.getElementById('passwordFeedback');
            
            let strength = 0;
            if (password.length >= 8) strength++;
            if (password.match(/[a-z]/) && password.match(/[A-Z]/)) strength++;
            if (password.match(/[0-9]/)) strength++;
            if (password.match(/[^a-zA-Z0-9]/)) strength++;
            
            const colors = ['bg-slate-200', 'bg-red-400', 'bg-yellow-400', 'bg-sky-400', 'bg-green-400'];
            const texts = [
                'Use 8+ characters with mix of letters, numbers & symbols',
                'Weak - Add more characters',
                'Fair - Add uppercase or numbers',
                'Good - Add special characters',
                'Strong password!'
            ];
            
            bars.forEach((bar, index) => {
                if (index < strength) {
                    bar.className = `h-1 flex-1 rounded-full ${colors[strength]} transition`;
                } else {
                    bar.className = 'h-1 flex-1 rounded-full bg-slate-200 transition';
                }
            });
            
            feedback.textContent = texts[strength];
            feedback.className = `text-xs mt-1 ${strength <= 1 ? 'text-red-500' : strength === 2 ? 'text-yellow-600' : strength === 3 ? 'text-sky-600' : 'text-green-600'}`;
            
            return strength >= 3;
        }

        // Social Signup
        function socialSignup(provider) {
            showToast(`Redirecting to ${provider}...`);
            // Simulate redirect
            setTimeout(() => {
                console.log(`Signup with ${provider}`);
            }, 1000);
        }

        // Handle Signup
        function handleSignup(e) {
            e.preventDefault();
            
            const form = e.target;
            const submitBtn = document.getElementById('submitBtn');
            const originalContent = submitBtn.innerHTML;
            
            // Validate all fields
            const isUsernameValid = validateUsername(form.firstName);
            const isEmailValid = validateEmail(form.email);
            const isPasswordStrong = checkPasswordStrength(form.password.value);
            const passwordsMatch = form.password.value === form.confirmPassword.value;
            
            if (!passwordsMatch) {
                showToast('Passwords do not match!', 'error');
                form.confirmPassword.focus();
                return;
            }
            
            if (!isPasswordStrong) {
                showToast('Please use a stronger password', 'error');
                form.password.focus();
                return;
            }
            
            // Show loading state
            submitBtn.disabled = true;
            submitBtn.innerHTML = '<div class="loader w-5 h-5 border-2 border-white rounded-full"></div><span>Creating account...</span>';
            
            // Simulate API call
            setTimeout(() => {
                // Success
                showToast('Welcome to Sky Blog! Redirecting...', 'success');
                
                // Reset button
                submitBtn.innerHTML = '<i class="fas fa-check"></i><span>Success!</span>';
                submitBtn.classList.remove('from-sky-500', 'to-indigo-600');
                submitBtn.classList.add('bg-green-500');
                
                // Redirect simulation
                setTimeout(() => {
                    // window.location.href = '/dashboard';
                    console.log('Redirect to dashboard');
                }, 1500);
            }, 2000);
        }

        // Enhanced Toast Function
        function showToast(message, type = 'success') {
            const toast = document.getElementById('toast');
            const toastMessage = document.getElementById('toastMessage');
            const icon = toast.querySelector('i');
            
            toastMessage.textContent = message;
            
            if (type === 'error') {
                icon.className = 'fas fa-exclamation-circle text-red-400';
                toast.querySelector('div').className = 'bg-slate-800 text-white px-6 py-3 rounded-lg shadow-lg flex items-center gap-3 border border-red-500/30';
            } else {
                icon.className = 'fas fa-check-circle text-sky-400';
                toast.querySelector('div').className = 'bg-slate-800 text-white px-6 py-3 rounded-lg shadow-lg flex items-center gap-3 border border-sky-500/30';
            }
            
            toast.classList.remove('translate-y-20', 'opacity-0');
            
            setTimeout(() => {
                toast.classList.add('translate-y-20', 'opacity-0');
            }, 3000);
        }
    </script>
</body>
</html>