<!-- Featured Section -->
<section id="featured" class="py-20 bg-gradient-to-b from-sky-50 to-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between items-end mb-12">
            <div>
                <span class="text-sky-600 font-semibold text-sm uppercase tracking-wider">Editor's Pick</span>
                <h2 class="font-serif text-4xl font-bold text-slate-800 mt-2">Headliners</h2>
            </div>
            <a href="#" class="hidden md:flex items-center text-slate-600 hover:text-sky-600 font-medium transition">
                View all <i class="fas fa-arrow-right ml-2"></i>
            </a>
        </div>

        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
            <% const featured = [
                {
                    title: "The Future of Urban Air Mobility",
                    excerpt: "How flying taxis and drone delivery are reshaping our cities and skylines.",
                    image: "https://images.unsplash.com/photo-1480714378408-67cf0d13bc1b?w=600&q=80",
                    category: "Technology",
                    author: "Alex Rivera",
                    authorImg: "https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=100&q=80",
                    date: "Dec 14, 2025",
                    readTime: "12 min",
                    featured: true
                },
                {
                    title: "Cloud Architecture: Designing for Scale",
                    excerpt: "Lessons from the sky: How cloud formations inspire modern infrastructure design.",
                    image: "https://images.unsplash.com/photo-1534088568595-a066f410bcda?w=600&q=80",
                    category: "Design",
                    author: "Emma Watson",
                    authorImg: "https://images.unsplash.com/photo-1438761681033-6461ffad8d80?w=100&q=80",
                    date: "Dec 13, 2025",
                    readTime: "8 min",
                    featured: false
                },
                {
                    title: "The Psychology of Open Spaces",
                    excerpt: "Why humans crave vast horizons and how architecture can provide them.",
                    image: "https://images.unsplash.com/photo-1464822759023-fed622ff2c3b?w=600&q=80",
                    category: "Lifestyle",
                    author: "James Chen",
                    authorImg: "https://images.unsplash.com/photo-1472099645785-5658abf4ff4e?w=100&q=80",
                    date: "Dec 12, 2025",
                    readTime: "10 min",
                    featured: false
                }
            ] %>

            <% featured.forEach((post, index) => { %>
            <article class="card-hover bg-white rounded-2xl overflow-hidden shadow-sm border border-slate-100">
                <div class="image-zoom relative h-56">
                    <img src="<%= post.image %>" alt="<%= post.title %>" class="w-full h-full object-cover">
                    <% if (post.featured) { %>
                    <div class="absolute top-4 left-4">
                        <span class="sunset-badge text-white text-xs font-bold px-3 py-1 rounded-full">
                            <i class="fas fa-fire mr-1"></i> TRENDING
                        </span>
                    </div>
                    <% } %>
                    <div class="absolute top-4 right-4">
                        <button onclick="toggleBookmark(this)" class="w-10 h-10 rounded-full bg-white/90 backdrop-blur flex items-center justify-center text-slate-400 hover:text-sky-500 transition shadow-lg">
                            <i class="far fa-bookmark"></i>
                        </button>
                    </div>
                </div>
                <div class="p-6">
                    <div class="flex items-center gap-2 text-sm text-slate-500 mb-3">
                        <span class="text-sky-600 font-semibold"><%= post.category %></span>
                        <span class="w-1 h-1 bg-slate-300 rounded-full"></span>
                        <span><%= post.readTime %> read</span>
                    </div>
                    <h3 class="font-serif text-xl font-bold text-slate-800 mb-2 line-clamp-2 hover:text-sky-600 transition cursor-pointer">
                        <%= post.title %>
                    </h3>
                    <p class="text-slate-600 text-sm mb-4 line-clamp-2">
                        <%= post.excerpt %>
                    </p>
                    <div class="flex items-center justify-between pt-4 border-t border-slate-100">
                        <div class="flex items-center gap-3">
                            <img src="<%= post.authorImg %>" alt="<%= post.author %>" class="w-8 h-8 rounded-full object-cover">
                            <div>
                                <div class="text-sm font-medium text-slate-800"><%= post.author %></div>
                                <div class="text-xs text-slate-500"><%= post.date %></div>
                            </div>
                        </div>
                        <div class="flex gap-2">
                            <button class="text-slate-400 hover:text-rose-500 transition">
                                <i class="far fa-heart"></i>
                            </button>
                            <button class="text-slate-400 hover:text-sky-500 transition">
                                <i class="far fa-comment"></i>
                            </button>
                        </div>
                    </div>
                </div>
            </article>
            <% }) %>
        </div>
    </div>
</section>