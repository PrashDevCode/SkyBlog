<!-- Hero Section -->
<section class="relative pt-20 min-h-screen flex items-center sky-gradient overflow-hidden">
    <!-- Animated Background Elements -->
    <div class="absolute inset-0 overflow-hidden">
        <!-- Clouds -->
        <div class="absolute top-20 left-10 w-64 h-20 bg-white/20 rounded-full blur-xl floating"></div>
        <div class="absolute top-40 right-20 w-80 h-24 bg-white/10 rounded-full blur-2xl drifting" style="animation-delay: 2s;"></div>
        <div class="absolute bottom-32 left-1/4 w-96 h-32 bg-white/15 rounded-full blur-3xl floating" style="animation-delay: 4s;"></div>
        
        <!-- Sun -->
        <div class="absolute -top-20 -right-20 w-96 h-96 bg-gradient-to-br from-yellow-300 to-orange-400 rounded-full opacity-30 blur-3xl"></div>
        
        <!-- Birds -->
        <div class="absolute top-1/3 left-1/4 text-white/20 text-4xl drifting" style="animation-duration: 12s;">
            <i class="fas fa-dove"></i>
        </div>
        <div class="absolute top-1/2 right-1/3 text-white/10 text-2xl drifting" style="animation-duration: 15s; animation-delay: 3s;">
            <i class="fas fa-dove"></i>
        </div>
        
        <div class="absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2 w-full h-full opacity-10">
            <div class="marquee-container">
                <div class="marquee-content text-9xl font-serif text-white/20">
                    SOAR • DREAM • EXPLORE • DISCOVER • WANDER • ASCEND • BREATHE •
                </div>
            </div>
        </div>
    </div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20">
        <div class="grid lg:grid-cols-2 gap-12 items-center">
            <!-- Hero Content -->
            <div class="text-white space-y-8">
                <div class="inline-flex items-center px-4 py-2 rounded-full bg-white/20 border border-white/30 backdrop-blur-sm">
                    <span class="w-2 h-2 bg-yellow-300 rounded-full mr-2 animate-pulse"></span>
                    <span class="text-sm font-medium">New horizons daily</span>
                </div>
                
                <h1 class="font-serif text-5xl md:text-7xl font-bold leading-tight">
                    Ideas That <br>
                    <span class="text-transparent bg-clip-text bg-gradient-to-r from-yellow-200 to-orange-200">Soar Beyond</span>
                </h1>
                
                <p class="text-xl text-sky-100 max-w-lg leading-relaxed">
                    Explore stories, insights, and perspectives from writers around the globe. Your next great read is just above the clouds.
                </p>
                
                <div class="flex flex-wrap gap-4">
                    <a href="/signup" class="px-8 py-4 bg-white text-sky-600 rounded-full font-semibold hover:shadow-xl hover:shadow-white/20 transition transform hover:scale-105 inline-flex items-center gap-2">
                        Start Writing Free
                        <i class="fas fa-arrow-right"></i>
                    </a>
                    <button onclick="document.getElementById('latest').scrollIntoView({behavior: 'smooth'})" 
                        class="px-8 py-4 bg-white/10 backdrop-blur-sm border border-white/30 text-white rounded-full font-semibold hover:bg-white/20 transition">
                        Explore Stories
                    </button>
                </div>

                <!-- Stats -->
                <div class="flex gap-8 pt-8 border-t border-white/20">
                    <div>
                        <div class="text-3xl font-bold text-white">50K+</div>
                        <div class="text-sm text-sky-100">Readers</div>
                    </div>
                    <div>
                        <div class="text-3xl font-bold text-white">1,200+</div>
                        <div class="text-sm text-sky-100">Stories</div>
                    </div>
                    <div>
                        <div class="text-3xl font-bold text-white">300+</div>
                        <div class="text-sm text-sky-100">Writers</div>
                    </div>
                </div>
            </div>

            <!-- Hero Card -->
            <div class="relative hidden lg:block">
                <div class="relative z-10 transform rotate-2 hover:rotate-0 transition duration-500">
                    <div class="cloud-card rounded-3xl overflow-hidden shadow-2xl shadow-sky-900/20">
                        <div class="relative h-64 overflow-hidden">
                            <img src="https://images.unsplash.com/photo-1506905925346-21bda4d32df4?w=800&q=80" 
                                alt="Mountain peaks above clouds" class="w-full h-full object-cover">
                            <div class="absolute top-4 left-4">
                                <span class="sunset-badge text-white text-xs font-bold px-3 py-1 rounded-full">
                                    <i class="fas fa-star mr-1"></i> FEATURED
                                </span>
                            </div>
                        </div>
                        <div class="p-6">
                            <div class="flex items-center gap-2 text-sm text-slate-500 mb-3">
                                <span class="text-sky-600 font-semibold">Adventure</span>
                                <span>•</span>
                                <span>8 min read</span>
                            </div>
                            <h3 class="font-serif text-2xl font-bold text-slate-800 mb-2">
                                Chasing Horizons: Why We Seek the Unknown
                            </h3>
                            <p class="text-slate-600 mb-4 line-clamp-2">
                                Exploring the human desire to discover what lies beyond the next mountain, the next cloud, the next idea.
                            </p>
                            <div class="flex items-center justify-between">
                                <div class="flex items-center gap-3">
                                    <img src="https://images.unsplash.com/photo-1494790108377-be9c29b29330?w=100&q=80" 
                                        class="w-10 h-10 rounded-full object-cover border-2 border-sky-100">
                                    <div>
                                        <div class="text-sm font-semibold text-slate-800">Elena Sky</div>
                                        <div class="text-xs text-slate-500">Dec 15, 2025</div>
                                    </div>
                                </div>
                                <button class="text-sky-500 hover:text-sky-600">
                                    <i class="fas fa-arrow-right"></i>
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
                <!-- Decorative clouds -->
                <div class="absolute -top-10 -right-10 w-32 h-12 bg-white/40 rounded-full blur-xl"></div>
                <div class="absolute -bottom-5 -left-5 w-40 h-16 bg-white/30 rounded-full blur-xl"></div>
            </div>
        </div>
    </div>

    <!-- Scroll Indicator -->
    <div class="absolute bottom-8 left-1/2 transform -translate-x-1/2 text-white/70 animate-bounce">
        <i class="fas fa-chevron-down text-2xl"></i>
    </div>
</section>