<!-- Latest Articles -->
<section id="latest" class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-12 gap-4">
            <div>
                <span class="text-sky-600 font-semibold text-sm uppercase tracking-wider">Fresh Air</span>
                <h2 class="font-serif text-4xl font-bold text-slate-800 mt-2">New Horizons</h2>
            </div>
            
            <div class="flex gap-2 overflow-x-auto pb-2 md:pb-0 w-full md:w-auto">
                <button onclick="filterPosts('all')" class="filter-btn active px-4 py-2 rounded-full text-sm font-medium bg-sky-600 text-white transition" data-filter="all">All</button>
                <button onclick="filterPosts('tech')" class="filter-btn px-4 py-2 rounded-full text-sm font-medium bg-slate-100 text-slate-600 hover:bg-sky-50 transition" data-filter="tech">Tech</button>
                <button onclick="filterPosts('design')" class="filter-btn px-4 py-2 rounded-full text-sm font-medium bg-slate-100 text-slate-600 hover:bg-sky-50 transition" data-filter="design">Design</button>
                <button onclick="filterPosts('business')" class="filter-btn px-4 py-2 rounded-full text-sm font-medium bg-slate-100 text-slate-600 hover:bg-sky-50 transition" data-filter="business">Business</button>
            </div>
        </div>

        <div class="grid lg:grid-cols-2 gap-8" id="articlesGrid">
            <% const articles = [
                {
                    title: "Serverless Architecture at 30,000 Feet",
                    excerpt: "How cloud computing is becoming as invisible and essential as the air we breathe.",
                    image: "https://images.unsplash.com/photo-1451187580459-43490279c0fa?w=600&q=80",
                    category: "Technology",
                    tag: "tech",
                    author: "Maria Garcia",
                    authorImg: "https://images.unsplash.com/photo-1494790108377-be9c29b29330?w=100&q=80",
                    date: "2 hours ago",
                    readTime: "15 min",
                    views: "2.4k"
                },
                {
                    title: "The Color of Clear Skies: Design Trends 2026",
                    excerpt: "Why blue is making a comeback in UI design and what it means for user psychology.",
                    image: "https://images.unsplash.com/photo-1495616811223-4d98c6e9d869?w=600&q=80",
                    category: "Design",
                    tag: "design",
                    author: "Lucas Kim",
                    authorImg: "https://images.unsplash.com/photo-1500648767791-00dcc994a43e?w=100&q=80",
                    date: "4 hours ago",
                    readTime: "6 min",
                    views: "1.8k"
                },
                {
                    title: "Airline Industry Disruption: The New Altitude",
                    excerpt: "How startups are reimagining air travel for the carbon-conscious generation.",
                    image: "https://images.unsplash.com/photo-1436491865332-7a61a109cc05?w=600&q=80",
                    category: "Business",
                    tag: "business",
                    author: "Priya Patel",
                    authorImg: "https://images.unsplash.com/photo-1534528741775-53994a69daeb?w=100&q=80",
                    date: "6 hours ago",
                    readTime: "20 min",
                    views: "3.2k"
                },
                {
                    title: "Breathing Room: Minimalism in Digital Spaces",
                    excerpt: "Creating mental clarity through generous whitespace and intentional design.",
                    image: "https://images.unsplash.com/photo-1517483000871-1dbf64a6e1c6?w=600&q=80",
                    category: "Design",
                    tag: "design",
                    author: "Tom Anderson",
                    authorImg: "https://images.unsplash.com/photo-1506794778202-cad84cf45f1d?w=100&q=80",
                    date: "8 hours ago",
                    readTime: "7 min",
                    views: "956"
                }
            ] %>

            <% articles.forEach(article => { %>
            <article class="article-card flex flex-col md:flex-row gap-6 p-4 rounded-2xl hover:bg-sky-50/50 transition border border-transparent hover:border-sky-100" data-category="<%= article.tag %>">
                <div class="image-zoom w-full md:w-48 h-48 md:h-32 rounded-xl overflow-hidden flex-shrink-0">
                    <img src="<%= article.image %>" alt="<%= article.title %>" class="w-full h-full object-cover">
                </div>
                <div class="flex-1 flex flex-col justify-between">
                    <div>
                        <div class="flex items-center gap-2 text-xs text-slate-500 mb-2">
                            <span class="text-sky-600 font-semibold uppercase tracking-wider"><%= article.category %></span>
                            <span>•</span>
                            <span><%= article.readTime %> read</span>
                        </div>
                        <h3 class="font-serif text-lg font-bold text-slate-800 mb-2 hover:text-sky-600 transition cursor-pointer line-clamp-2">
                            <%= article.title %>
                        </h3>
                        <p class="text-slate-600 text-sm line-clamp-2 mb-3">
                            <%= article.excerpt %>
                        </p>
                    </div>
                    <div class="flex items-center justify-between">
                        <div class="flex items-center gap-2">
                            <img src="<%= article.authorImg %>" class="w-6 h-6 rounded-full object-cover border border-sky-200">
                            <span class="text-sm font-medium text-slate-800"><%= article.author %></span>
                            <span class="text-xs text-slate-400">• <%= article.date %></span>
                        </div>
                        <div class="flex items-center gap-3 text-slate-400 text-sm">
                            <span><i class="far fa-eye mr-1"></i><%= article.views %></span>
                            <button class="hover:text-sky-500 transition"><i class="far fa-bookmark"></i></button>
                        </div>
                    </div>
                </div>
            </article>
            <% }) %>
        </div>

        <div class="text-center mt-12">
            <button onclick="loadMore()" id="loadMoreBtn" class="px-8 py-3 border-2 border-sky-600 text-sky-600 rounded-full font-semibold hover:bg-sky-600 hover:text-white transition">
                Load More Stories
            </button>
            <div id="loader" class="hidden">
                <div class="loader ease-linear rounded-full border-4 border-t-4 border-slate-200 h-12 w-12 mx-auto"></div>
            </div>
        </div>
    </div>
</section>