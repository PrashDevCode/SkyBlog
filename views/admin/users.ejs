<%- include('../partials/admin-layout-top', { pageTitle: 'Manage Users' }) %>

    <div class="flex items-center justify-between mb-6">
      <p class="text-sm text-gray-400"><%= users.length %> total users</p>
    </div>

    <div class="bg-white border border-gray-200 rounded-lg shadow-sm overflow-hidden">
      <table class="w-full text-sm">
        <thead class="border-b border-gray-200 bg-gray-50">
          <tr>
            <th class="text-left px-6 py-3 text-xs uppercase tracking-widest text-gray-400 font-medium">User</th>
            <th class="text-left px-6 py-3 text-xs uppercase tracking-widest text-gray-400 font-medium">Email</th>
            <th class="text-left px-6 py-3 text-xs uppercase tracking-widest text-gray-400 font-medium">Role</th>
            <th class="text-left px-6 py-3 text-xs uppercase tracking-widest text-gray-400 font-medium">Joined</th>
            <th class="text-left px-6 py-3 text-xs uppercase tracking-widest text-gray-400 font-medium">Actions</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
          <% users.forEach(u => { %>
            <tr class="hover:bg-gray-50 transition">
              <td class="px-6 py-4">
                <div class="flex items-center gap-3">
                  <img src="<%= u.profileImageURL || '/user.png' %>"
                    class="w-8 h-8 rounded-full object-cover border border-gray-200" />
                  <span class="font-medium"><%= u.fullName %></span>
                </div>
              </td>
              <td class="px-6 py-4 text-gray-500"><%= u.email %></td>
              <td class="px-6 py-4">
                <form action="/admin/users/<%= u._id %>/role" method="POST" class="flex items-center gap-2">
                  <select name="role"
                    class="text-xs border border-gray-200 rounded px-2 py-1 bg-white outline-none focus:border-black">
                    <option value="user" <%= u.role === 'user' ? 'selected' : '' %>>User</option>
                    <option value="admin" <%= u.role === 'admin' ? 'selected' : '' %>>Admin</option>
                  </select>
                  <button type="submit" class="text-xs text-gray-400 hover:text-black underline">Save</button>
                </form>
              </td>
              <td class="px-6 py-4 text-gray-400 text-xs"><%= new Date(u.createdAt).toDateString() %></td>
              <td class="px-6 py-4">
                <form action="/admin/users/<%= u._id %>/delete" method="POST"
                  onsubmit="return confirm('Delete this user and all their content?')">
                  <button type="submit" class="text-xs text-red-400 hover:text-red-600 transition">Delete</button>
                </form>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>

      </main>
    </div>
  </div>
<%- include('../partials/scripts') %>
</body>
</html>
