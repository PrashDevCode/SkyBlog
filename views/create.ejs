<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head') %>
  <!-- Quill Rich Text Editor -->
  <link href="https://cdn.quilljs.com/1.3.7/quill.snow.css" rel="stylesheet" />
</head>
<body class="bg-white text-black">

  <%- include('partials/navbar') %>

  <div class="max-w-3xl mx-auto px-4 sm:px-6 py-16">

    <h1 class="text-3xl font-bold mb-8"><%= locals.blog ? 'Edit Post' : 'Create New Post' %></h1>

    <!-- Error -->
    <% if (locals.error) { %>
      <div class="mb-6 px-4 py-3 bg-red-50 border border-red-200 text-red-600 text-sm rounded">
        <%= error %>
      </div>
    <% } %>

    <form
      action="<%= locals.blog ? `/blog/${blog._id}/edit` : '/blog/create' %>"
      method="POST"
      enctype="multipart/form-data"
      class="space-y-6"
    >

      <!-- Title -->
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Title</label>
        <input type="text" name="title" required
          value="<%= locals.blog ? blog.title : '' %>"
          placeholder="Your post title..."
          class="w-full px-4 py-3 border border-gray-300 rounded text-sm outline-none focus:border-black transition" />
      </div>

      <!-- Excerpt -->
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Excerpt <span class="text-gray-400">(short summary)</span></label>
        <input type="text" name="excerpt"
          value="<%= locals.blog ? blog.excerpt : '' %>"
          placeholder="A brief summary shown on blog cards..."
          class="w-full px-4 py-3 border border-gray-300 rounded text-sm outline-none focus:border-black transition" />
      </div>

      <!-- Cover Image -->
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Cover Image</label>
        <% if (locals.blog && blog.coverImage) { %>
          <img src="<%= blog.coverImage %>" class="h-32 object-cover rounded mb-2 border border-gray-200" />
        <% } %>
        <input type="file" name="coverImage" accept="image/*"
          class="w-full text-sm text-gray-500 file:mr-4 file:py-2 file:px-4 file:border file:border-gray-300 file:rounded file:text-sm file:bg-white file:hover:bg-gray-50 transition" />
      </div>

      <!-- Category -->
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Category</label>
        <select name="category"
          class="w-full px-4 py-3 border border-gray-300 rounded text-sm outline-none focus:border-black transition bg-white">
          <% ['Technology','Design','Culture','Business','Science','Other'].forEach(cat => { %>
            <option value="<%= cat %>" <%= locals.blog && blog.category === cat ? 'selected' : '' %>>
              <%= cat %>
            </option>
          <% }) %>
        </select>
      </div>

      <!-- Tags -->
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Tags <span class="text-gray-400">(comma separated)</span></label>
        <input type="text" name="tags"
          value="<%= locals.blog && blog.tags ? blog.tags.join(', ') : '' %>"
          placeholder="e.g. nodejs, express, mongodb"
          class="w-full px-4 py-3 border border-gray-300 rounded text-sm outline-none focus:border-black transition" />
      </div>

      <!-- Rich Text Editor -->
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Content</label>
        <div id="editor" class="border border-gray-300 rounded min-h-64 text-sm">
          <%- locals.blog ? blog.content : '' %>
        </div>
        <!-- Hidden input to submit Quill content -->
        <input type="hidden" name="content" id="content" />
      </div>

      <!-- Draft / Publish Toggle -->
<div>
  <label class="block text-sm font-medium text-gray-700 mb-2">Status</label>
  <div class="flex gap-4">
    <label class="flex items-center gap-2 cursor-pointer">
      <input type="radio" name="status" value="draft"
        <%= locals.blog && blog.status === 'draft' ? 'checked' : '' %> />
      <span class="text-sm text-gray-600">Save as Draft</span>
    </label>
    <label class="flex items-center gap-2 cursor-pointer">
      <input type="radio" name="status" value="published"
        <%= !locals.blog || blog.status === 'published' ? 'checked' : '' %> />
      <span class="text-sm text-gray-600">Publish Now</span>
    </label>
  </div>
</div>

      <!-- Submit -->
      <div class="flex gap-4 pt-4 border-t border-gray-200">
        <button type="submit"
          class="px-6 py-3 bg-black text-white text-sm font-medium rounded hover:bg-gray-800 transition">
          <%= locals.blog ? 'Update Post' : 'Create Post' %>
        </button>
        <a href="/" class="px-6 py-3 border border-gray-300 text-sm rounded hover:bg-gray-50 transition">
          Cancel
        </a>
      </div>

    </form>
  </div>

  <!-- FOOTER -->
  <footer class="border-t border-gray-200 py-8 text-center text-xs text-gray-400">
    © <%= new Date().getFullYear() %> SkyBlog. All rights reserved.
  </footer>

  <!-- Quill JS -->
  <script src="https://cdn.quilljs.com/1.3.7/quill.min.js"></script>
  <script>
    const quill = new Quill('#editor', {
      theme: 'snow',
      placeholder: 'Write your post here...',
      modules: {
        toolbar: [
          [{ header: [1, 2, 3, false] }],
          ['bold', 'italic', 'underline', 'strike'],
          ['blockquote', 'code-block'],
          [{ list: 'ordered' }, { list: 'bullet' }],
          ['link', 'image'],
          ['clean']
        ]
      }
    });

    // On form submit, copy Quill HTML into hidden input
    document.querySelector('form').addEventListener('submit', () => {
      document.getElementById('content').value = quill.root.innerHTML;
    });
  </script>

  <%- include('partials/scripts') %>
</body>
</html>