          </a>
          <% } else { %>
            <!-- Not logged in -->
            <a href="/user/signin" class="text-sm px-4 py-2 text-gray-700 hover:text-black transition">
              Sign In
            </a>
            <a href="/user/signup" class="text-sm px-4 py-2 bg-black text-white rounded hover:bg-gray-800 transition">
