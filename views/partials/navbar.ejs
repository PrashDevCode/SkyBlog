<nav class="border-b border-gray-200 bg-white sticky top-0 z-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between items-center h-16">

      <!-- Logo -->
      <a href="/" class="text-2xl font-bold tracking-tight text-black" style="font-family:'Playfair Display',serif;">
        Sky<span class="text-gray-400">Blog</span>
      </a>

      <!-- Nav Links -->
      <div class="hidden md:flex items-center gap-8 text-sm font-medium text-gray-600">
        <a href="/" class="hover:text-black transition">Home</a>
        <a href="/blog" class="hover:text-black transition">Blog</a>
        <a href="/blog/create" class="hover:text-black transition">Write</a>
        <a href="/user/dashboard" class="hover:text-black transition">Dashboard</a>
        <a href="/admin" class="hover:text-black transition text-red-500">Admin</a>
      </div>

      <!-- Auth Buttons -->
      <div class="flex items-center gap-3">
