<!DOCTYPE html>
<html lang="en">
<head><%- include('partials/head') %></head>
<body class="bg-white text-black">

  <%- include('partials/navbar') %>

  <div class="max-w-4xl mx-auto px-4 sm:px-6 py-16">

    <!-- Profile Header -->
    <div class="flex flex-col sm:flex-row items-center sm:items-start gap-8 pb-10 border-b border-gray-200">

      <!-- Avatar -->
      <div class="relative">
        <img
          src="<%= profileUser.profileImageURL || '/user.png' %>"
          alt="<%= profileUser.fullName %>"
          class="w-24 h-24 rounded-full object-cover border border-gray-200"
        />
      </div>

      <!-- Info -->
      <div class="flex-1 text-center sm:text-left">
        <h1 class="text-3xl font-bold"><%= profileUser.fullName %></h1>
        <p class="text-gray-500 text-sm mt-1"><%= profileUser.email %></p>
        <span class="inline-block mt-2 text-xs px-3 py-1 border border-gray-200 rounded-full text-gray-500 capitalize">
          <%= profileUser.role %>
        </span>
        <p class="text-xs text-gray-400 mt-2">
          Member since <%= new Date(profileUser.createdAt).toDateString() %>
        </p>
      </div>

      <!-- Edit Button (only own profile) -->
      <% if (locals.user && user._id === profileUser._id.toString()) { %>
        <button onclick="document.getElementById('editModal').classList.remove('hidden')"
          class="text-sm px-4 py-2 border border-black rounded hover:bg-black hover:text-white transition">
          Edit Profile
        </button>
      <% } %>

    </div>

    <!-- Stats -->
    <div class="grid grid-cols-3 gap-4 py-8 border-b border-gray-200">
      <div class="text-center">
        <p class="text-3xl font-bold"><%= totalBlogs %></p>
        <p class="text-xs text-gray-400 mt-1 uppercase tracking-widest">Total Posts</p>
      </div>
      <div class="text-center">
        <p class="text-3xl font-bold"><%= publishedBlogs %></p>
        <p class="text-xs text-gray-400 mt-1 uppercase tracking-widest">Published</p>
      </div>
      <div class="text-center">
        <p class="text-3xl font-bold"><%= draftBlogs %></p>
        <p class="text-xs text-gray-400 mt-1 uppercase tracking-widest">Drafts</p>
      </div>
    </div>

    <!-- Recent Posts -->
    <div class="py-8">
      <h2 class="text-xl font-bold mb-6">Recent Posts</h2>

      <% if (blogs.length > 0) { %>
        <div class="space-y-4">
          <% blogs.forEach(blog => { %>
            <a href="/blog/<%= blog._id %>"
              class="flex items-center justify-between p-4 border border-gray-200 rounded hover:shadow-sm transition group">
              <div class="flex-1">
                <div class="flex items-center gap-2 mb-1">
                  <% if (blog.category) { %>
                    <span class="text-xs text-gray-400 uppercase tracking-widest"><%= blog.category %></span>
                  <% } %>
                  <% if (blog.status === 'draft') { %>
                    <span class="text-xs px-2 py-0.5 bg-yellow-100 text-yellow-700 rounded">Draft</span>
                  <% } %>
                </div>
                <h3 class="text-sm font-semibold group-hover:underline"><%= blog.title %></h3>
                <p class="text-xs text-gray-400 mt-1"><%= new Date(blog.createdAt).toDateString() %></p>
              </div>
              <span class="text-gray-300 group-hover:text-black transition text-lg">→</span>
            </a>
          <% }) %>
        </div>
      <% } else { %>
        <div class="text-center py-16 text-gray-400">
          <p class="text-4xl mb-3">✍️</p>
          <p class="text-sm">No posts yet.</p>
          <a href="/blog/create" class="text-black text-sm underline mt-2 inline-block">Write your first post</a>
        </div>
      <% } %>
    </div>

  </div>

  <!-- Edit Profile Modal -->
  <div id="editModal" class="hidden fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center z-50 px-4">
    <div class="bg-white rounded w-full max-w-md p-8 relative">

      <button onclick="document.getElementById('editModal').classList.add('hidden')"
        class="absolute top-4 right-4 text-gray-400 hover:text-black text-xl">✕</button>

      <h2 class="text-xl font-bold mb-6">Edit Profile</h2>

      <form action="/user/profile/update" method="POST" enctype="multipart/form-data" class="space-y-5">

        <!-- Avatar Preview -->
        <div class="flex items-center gap-4">
          <img id="avatarPreview"
            src="<%= profileUser.profileImageURL || '/user.png' %>"
            class="w-16 h-16 rounded-full object-cover border border-gray-200" />
          <div>
            <label class="text-sm font-medium text-gray-700 block mb-1">Profile Picture</label>
            <input type="file" name="profileImage" accept="image/*"
              onchange="previewAvatar(event)"
              class="text-xs text-gray-500 file:mr-2 file:py-1 file:px-3 file:border file:border-gray-300 file:rounded file:text-xs file:bg-white" />
          </div>
        </div>

        <!-- Full Name -->
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Full Name</label>
          <input type="text" name="fullName" value="<%= profileUser.fullName %>" required
            class="w-full px-4 py-3 border border-gray-300 rounded text-sm outline-none focus:border-black transition" />
        </div>

        <button type="submit"
          class="w-full py-3 bg-black text-white text-sm font-medium rounded hover:bg-gray-800 transition">
          Save Changes
        </button>

      </form>
    </div>
  </div>

  <!-- FOOTER -->
  <footer class="border-t border-gray-200 py-8 text-center text-xs text-gray-400">
    © <%= new Date().getFullYear() %> SkyBlog. All rights reserved.
  </footer>

  <script>
    function previewAvatar(event) {
      const reader = new FileReader();
      reader.onload = () => {
        document.getElementById('avatarPreview').src = reader.result;
      };
      reader.readAsDataURL(event.target.files[0]);
    }
  </script>

  <%- include('partials/scripts') %>
</body>
</html>